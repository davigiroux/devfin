# Neon Postgres (pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.neon.tech/dbname?sslmode=require

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-byte-base64
# In prod (Netlify) Auth.js reads the URL from the host header; override locally if needed.
# AUTH_URL=http://localhost:3000
